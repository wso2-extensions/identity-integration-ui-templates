                },
                {
                    "id": "callback-url",
                    "aria-label": "Authorized Redirect URL",
                    "name": "inboundProtocolConfiguration.oidc.callbackURLs.[0]",
                    "label": "Authorized Redirect URL",
                    "type": "text",
                    "required": true,
                    "placeholder": "https://myapp.io/login",
                    "dataComponentId": "vue-create-wizard-callback-url"
